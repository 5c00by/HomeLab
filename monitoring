version: '3.8'

services:
  watchtower:
    image: containrrr/watchtower:latest
    container_name: watchtower
    environment:
      - WATCHTOWER_CLEANUP=true # Deletes old images so your fast SSD doesn't fill up with docker junk
      - WATCHTOWER_POLL_INTERVAL=86400 # Checks for updates once every 24 hours
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    restart: unless-stopped

  dozzle:
    image: amir20/dozzle:latest
    container_name: dozzle
    ports:
      - 8888:8080
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    restart: unless-stopped
